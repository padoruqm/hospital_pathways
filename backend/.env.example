# Sao chép file này thành `.env` rồi điền giá trị thật.
# Ở Giai đoạn 1 backend chưa cần khoá AI; biến dưới để sẵn cho giai đoạn tích hợp Gemini.

# Cổng chạy Flask (mặc định 5001 để tránh đụng AirPlay Receiver chiếm 5000 trên macOS)
PORT=5001

# Khoá Google Gemini API — sẽ dùng ở Giai đoạn 2 (chatbot RAG) và 3 (OCR).
GEMINI_API_KEY=
