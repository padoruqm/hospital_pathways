# Sao chép file này thành `.env` rồi điền giá trị thật.

# Cổng chạy Flask (mặc định 5057 để tránh đụng AirPlay Receiver chiếm 5000 trên macOS)
PORT=5057

# Khoá Google Gemini API — dùng cho chatbot AI (POST /api/ai/chat).
# Lấy miễn phí tại Google AI Studio (key chuẩn bắt đầu bằng "AIza").
# Bỏ trống vẫn chạy web, chỉ riêng chat báo cần key.
GEMINI_API_KEY=

# (Tuỳ chọn) Model dùng cho chatbot. Mặc định gemini-2.0-flash (truy cập rộng ở free tier).
# Nếu key được cấp quyền model mới hơn, có thể đổi: GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL=gemini-2.0-flash